{
  "name": "nova-safety",
  "description": "NOVA Safety — наряд-допуск (веб-приложение)",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && firebase deploy",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "fcm:fetch-vapid": "node scripts/fetch-fcm-vapid.mjs",
    "fcm:set-vapid": "node scripts/register-fcm-vapid.mjs",
    "fcm:setup": "node scripts/fetch-fcm-vapid.mjs || echo Run: npm run fcm:set-vapid -- YOUR_PUBLIC_KEY",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "cd functions && npm run build && cd .. && firebase deploy --only functions && node functions/scripts/ensure-public-invoker.mjs",
    "deploy:all": "npm run build && cd functions && npm run build && cd .. && firebase deploy && node functions/scripts/ensure-public-invoker.mjs",
    "release:227580:assemble": "node scripts/assemble-release-227580.mjs",
    "deploy:release-227580": "node scripts/assemble-release-227580.mjs && node scripts/deploy-release-227580.mjs",
    "clone:release-227580": "node scripts/clone-release-227580-workspace.mjs",
    "snapshot:live:fetch": "node scripts/fetch-live-hosting-snapshot.mjs",
    "deploy:snapshot-6c61f9": "node scripts/deploy-snapshot-6c61f9.mjs",
    "snapshot:6c61f9:fetch-and-deploy": "node scripts/fetch-live-hosting-snapshot.mjs 6c61f9 && node scripts/deploy-snapshot-6c61f9.mjs",
    "bootstrap-admin": "node scripts/bootstrap-admin.mjs",
    "bootstrap-roles": "node scripts/bootstrap-role-users.mjs",
    "bootstrap-roles:firebase": "node scripts/bootstrap-roles-firebase-cli.mjs",
    "clear-permits": "node scripts/clear-permits.mjs",
    "generate-tz-docx": "node scripts/generate-tz-docx.mjs"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.5",
    "firebase": "^12.12.1",
    "lottie-react": "^2.4.1",
    "lottie-web": "^5.13.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfmake": "^0.3.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "sigex-qr-signing-client": "^0.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "docx": "^9.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^14.0.0",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0"
  }
}
