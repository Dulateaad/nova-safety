rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Клиент только для вошедших пользователей (Firebase Auth email/password).
    // Профили вручную: users/{uid} — displayName, role, опционально email.

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if false;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['notificationEmail', 'updatedAtIso'])
        && request.resource.data.notificationEmail is string
        && (
          request.auth.uid == userId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator'
        );
    }

    match /permits/{permitId} {
      allow read, write: if request.auth != null;

      match /journal/{entryId} {
        allow read, write: if request.auth != null;
      }
    }

    // Сессии QR-подписания — только Cloud Functions (Admin SDK).
    match /signingSessions/{sessionId} {
      allow read: if request.auth != null
        && resource.data.signerUid == request.auth.uid;
      allow write: if false;
    }

    // Уведомления подписантам — только назначенный пользователь; координатор может удалять.
    match /signingInvites/{inviteId} {
      allow read: if request.auth != null
        && resource.data.assigneeUid == request.auth.uid;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator';
      allow write: if false;
    }

    match /workStopAlerts/{alertId} {
      allow read: if request.auth != null
        && resource.data.assigneeUid == request.auth.uid;
      allow write: if false;
    }

    match /permitNotices/{noticeId} {
      allow read: if request.auth != null
        && resource.data.assigneeUid == request.auth.uid;
      allow write: if false;
    }

    // FCM device-токены для web-push — владелец читает/пишет свои.
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Настройки приложения — чтение всем; запись координатором (verifyEgovFio).
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator'
        && request.resource.data.verifyEgovFio is bool;
      allow update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinator'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['verifyEgovFio', 'updatedAtIso', 'updatedByUid']);
      allow delete: if false;
    }
  }
}
